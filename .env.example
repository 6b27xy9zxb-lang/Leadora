# --- Supabase (free tier is plenty for this app) ---
# Get these from your Supabase project: Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
# Service role key, server-only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# --- Groq (free tier) — powers the AI cold-call / prompt generator ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx
# Optional — defaults to llama-3.3-70b-versatile if unset.
# Check https://console.groq.com/docs/models for the current free-tier list.
GROQ_MODEL=llama-3.3-70b-versatile

# Lead search itself needs no key — it runs on the free OpenStreetMap
# Overpass + Nominatim APIs, already baked into src/lib/leads.functions.ts.
